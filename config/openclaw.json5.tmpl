{
  meta: {
    lastTouchedVersion: "${OPENCLAW_VERSION}",
  },

  gateway: {
    mode: "local",
    bind: "${OPENCLAW_GATEWAY_BIND}",
    port: ${OPENCLAW_GATEWAY_PORT},
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    controlUi: {
      enabled: true,
      allowedOrigins: [
        "${OPENCLAW_CONTROL_UI_ORIGIN}",
      ],
    },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "${OPENCLAW_PRIMARY_MODEL}",
      },
      models: {
        "aliyun/qwen3.5-plus": {
          alias: "Qwen 3.5 Plus",
        },
        "aliyun/qwen-vl-max-latest": {
          alias: "Qwen VL Max",
        },
        "tencent/tc-code-latest": {
          alias: "Tencent Coding Auto",
        },
        "tencent/hunyuan-2.0-instruct": {
          alias: "Tencent HY 2.0 Instruct",
        },
        "tencent/hunyuan-2.0-thinking": {
          alias: "Tencent HY 2.0 Think",
        },
        "tencent/hunyuan-t1": {
          alias: "Tencent Hunyuan T1",
        },
        "tencent/hunyuan-turbos": {
          alias: "Tencent Hunyuan TurboS",
        },
        "tencent/minimax-m2.5": {
          alias: "MiniMax-M2.5",
        },
        "tencent/kimi-k2.5": {
          alias: "Kimi-K2.5",
        },
        "tencent/glm-5": {
          alias: "GLM-5",
        },
      },
      memorySearch: {
        enabled: ${MEMORY_SEARCH_ENABLED},
      },
    },
  },

  models: {
    mode: "merge",
    providers: {
      aliyun: {
        api: "openai-completions",
        baseUrl: "${ALIYUN_BASE_URL}",
        apiKey: "${ALIYUN_API_KEY}",
        models: [
          {
            id: "qwen3.5-plus",
            name: "Qwen 3.5 Plus",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "qwen-vl-max-latest",
            name: "Qwen VL Max",
            input: [
              "text",
              "image",
            ],
            reasoning: true,
          },
        ],
      },
      tencent: {
        api: "openai-completions",
        baseUrl: "${TENCENT_BASE_URL}",
        apiKey: "${TENCENT_API_KEY}",
        models: [
          {
            id: "tc-code-latest",
            name: "Tencent Coding Auto",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "hunyuan-2.0-instruct",
            name: "Tencent HY 2.0 Instruct",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "hunyuan-2.0-thinking",
            name: "Tencent HY 2.0 Think",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "hunyuan-t1",
            name: "Tencent Hunyuan T1",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "hunyuan-turbos",
            name: "Tencent Hunyuan TurboS",
            input: [
              "text",
            ],
            reasoning: true,
          },
          {
            id: "minimax-m2.5",
            name: "MiniMax-M2.5",
            input: [
              "text",
            ],
            reasoning: false,
          },
          {
            id: "kimi-k2.5",
            name: "Kimi-K2.5",
            input: [
              "text",
            ],
            reasoning: false,
          },
          {
            id: "glm-5",
            name: "GLM-5",
            input: [
              "text",
            ],
            reasoning: false,
          },
        ],
      },
    },
  },

  plugins: {
    enabled: true,
    allow: [
      "feishu",
      "memory-lancedb",
    ],
    slots: {
      memory: "memory-lancedb",
    },
    entries: {
      feishu: {
        enabled: true,
      },
      "memory-lancedb": {
        enabled: true,
        config: {
          autoCapture: true,
          autoRecall: true,
          dbPath: "~/.openclaw/memory/lancedb",
          embedding: {
            apiKey: "${MEMORY_EMBEDDING_API_KEY}",
            model: "${MEMORY_EMBEDDING_MODEL}",
            baseUrl: "${MEMORY_EMBEDDING_BASE_URL}",
            dimensions: ${MEMORY_EMBEDDING_DIMENSIONS},
          },
        },
      },
    },
  },

  channels: {
    feishu: {
      enabled: true,
      connectionMode: "websocket",
      domain: "${FEISHU_DOMAIN}",
      dmPolicy: "pairing",
      groupPolicy: "open",
      streaming: true,
      blockStreaming: true,
      accounts: {
        default: {
          appId: "${FEISHU_APP_ID}",
          appSecret: "${FEISHU_APP_SECRET}",
          botName: "${FEISHU_BOT_NAME}",
        },
      },
    },
  },
}